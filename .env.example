# ===========================================
# E-Visa Portal Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evisa_portal_dev?schema=public"

# JWT Authentication (Admin)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=604800

# Portal JWT (for customer portal)
JWT_PORTAL_ACCESS_SECRET=your-portal-access-secret-change-in-production
JWT_PORTAL_REFRESH_SECRET=your-portal-refresh-secret-change-in-production
JWT_PORTAL_ACCESS_EXPIRATION_SECONDS=3600
JWT_PORTAL_REFRESH_EXPIRATION_SECONDS=604800

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS_PER_HOUR=10

# Swagger Documentation
SWAGGER_TITLE="Visa Portal Backend API"
SWAGGER_DESCRIPTION="E-Visa Portal Backend API Documentation"
SWAGGER_VERSION=1.0.0

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Payment Configuration (placeholders)
PAYMENT_TIMEOUT_HOURS=3
DEFAULT_CURRENCY=USD

# Email Configuration
# EMAIL_PROVIDER: 'smtp', 'console', or 'auto' (default)
# - 'smtp': Use real SMTP sending (requires SMTP_* config below)
# - 'console': Log emails to console (for development)
# - 'auto': Use SMTP if configured, otherwise console
EMAIL_PROVIDER=auto

# SMTP Configuration (required when EMAIL_PROVIDER=smtp or auto with SMTP configured)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=E-Visa Portal

# Redis (optional, for future caching/sessions)
REDIS_URL=redis://127.0.0.1:6379

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug

# ===========================================
# Production-only settings (server-side)
# ===========================================

# APP_URL (used for email links, callbacks)
# APP_URL=https://yourdomain.com

# Backup Configuration (used by backup script)
# BACKUP_RETENTION_DAYS=14
