// ===========================================
// Visa Portal - Prisma Schema
// Production-ready database schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ENUMS
// ===========================================

// Entries feature — the old fixed VisaEntryType enum (SINGLE/DOUBLE/
// MULTIPLE) is gone. A visa type now owns many `VisaTypeEntry` rows,
// each with a FREE-STRING label (so admins can create CUSTOM entries)
// plus its own validity + max-stay window.

enum PermissionEffect {
  ALLOW
  DENY
}

enum OtpPurpose {
  LOGIN
  VERIFICATION
  PASSWORD_RESET
}

enum PaymentStatus {
  CREATED
  PENDING
  PROCESSING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ApplicationStatus {
  DRAFT
  UNPAID
  SUBMITTED
  IN_REVIEW
  NEED_DOCS
  APPROVED
  REJECTED
  READY_TO_DOWNLOAD
  CANCELLED
}

enum ApplicantStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEED_DOCS
  APPROVED
  REJECTED
  READY_TO_DOWNLOAD
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REUPLOAD
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DELIVERED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActorType {
  USER
  SYSTEM
  PORTAL_IDENTITY
}

enum TransactionType {
  INITIALIZATION
  AUTHORIZATION
  CAPTURE
  REFUND
  VOID
  CALLBACK
  STATUS_UPDATE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CallbackProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum SignatureValidationStatus {
  VALID
  INVALID
  NOT_CHECKED
  NOT_APPLICABLE
}

enum ReconciliationStatus {
  PENDING
  MATCHED
  MISMATCHED
  MANUAL_REVIEW
}

// ===========================================
// ACCESS CONTROL ENTITIES
// ===========================================

model User {
  id                    String    @id @default(uuid())
  fullName              String    @map("full_name")
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  roleId                String?   @map("role_id")
  isActive              Boolean   @default(true) @map("is_active")
  lastLoginAt           DateTime? @map("last_login_at")
  // M11.4 — first-login forced password change. Seeded super admins
  // start with this flag true; the change-password endpoint flips it
  // false and stamps `lastPasswordChangedAt`.
  mustChangePassword    Boolean   @default(false) @map("must_change_password")
  lastPasswordChangedAt DateTime? @map("last_password_changed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  role                      Role?                            @relation(fields: [roleId], references: [id])
  sessions                  Session[]
  passwordResetTokens       PasswordResetToken[]
  userPermissions           UserPermission[]
  applicationStatusHistory  ApplicationStatusHistory[]       @relation("ChangedByUser")
  applicantStatusHistory    ApplicantStatusHistory[]         @relation("ChangedByUser")
  applicationReviews        Application[]                    @relation("ApplicationReviewedByUser")
  applicationEstTimeChanges ApplicationEstimatedTimeChange[] @relation("EstTimeChangedBy")
  documentReviews           Document[]                       @relation("ReviewedByUser")
  paymentStatusHistory      PaymentStatusHistory[]           @relation("ChangedByUser")
  documentRequestsCreated   DocumentRequest[]                @relation("DocumentRequestRequestedByUser")
  auditLogs                 AuditLog[]
  // M-Assign — operator-side relations
  assignedApplications      Application[]                    @relation("ApplicationAssignedTo")
  assignmentsMade           Application[]                    @relation("ApplicationAssignedBy")
  internalNotesAuthored     ApplicationInternalNote[]
  assignmentHistoryAsPrev   ApplicationAssignmentHistory[]   @relation("AssignmentHistoryPreviousAssignee")
  assignmentHistoryAsNew    ApplicationAssignmentHistory[]   @relation("AssignmentHistoryNewAssignee")
  assignmentHistoryChanges  ApplicationAssignmentHistory[]   @relation("AssignmentHistoryChangedBy")
  // M11.14 (BUG FF) — operator-uploaded result files
  uploadedResultFiles       ApplicationResultFile[]
  // M11.15 (HELP) — help-article authoring back-relations
  helpArticlesCreated       HelpArticle[]                    @relation("HelpArticleCreator")
  helpArticlesUpdated       HelpArticle[]                    @relation("HelpArticleUpdater")

  @@index([email])
  @@index([roleId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  key         String    @unique
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users           User[]
  rolePermissions RolePermission[]

  @@index([key])
  @@index([isSystem])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id            String   @id @default(uuid())
  moduleKey     String   @map("module_key")
  actionKey     String   @map("action_key")
  permissionKey String   @unique @map("permission_key")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([moduleKey, actionKey])
  @@index([moduleKey])
  @@index([permissionKey])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  permissionId String           @map("permission_id")
  effect       PermissionEffect @default(ALLOW)
  createdAt    DateTime         @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@map("user_permissions")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  lastActivityAt   DateTime  @default(now()) @map("last_activity_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  revokedAt        DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

/// M11.4 — admin forgot-password flow.
/// Plain token only ever lives in the URL emailed to the user;
/// `tokenHash` is sha256(plainToken) so a leaked DB dump cannot be
/// replayed. `usedAt` flips on consumption so a token is single-use.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

// ===========================================
// PORTAL AUTH ENTITIES
// ===========================================

model PortalIdentity {
  id             String    @id @default(uuid())
  email          String    @unique
  isActive       Boolean   @default(true) @map("is_active")
  lastVerifiedAt DateTime? @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  portalSessions PortalSession[]
  applications   Application[]

  @@index([email])
  @@index([isActive])
  @@map("portal_identities")
}

model PortalSession {
  id               String    @id @default(uuid())
  portalIdentityId String    @map("portal_identity_id")
  refreshTokenHash String    @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  lastActivityAt   DateTime  @default(now()) @map("last_activity_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  revokedAt        DateTime? @map("revoked_at")

  portalIdentity PortalIdentity @relation(fields: [portalIdentityId], references: [id], onDelete: Cascade)

  @@index([portalIdentityId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("portal_sessions")
}

model OtpCode {
  id        String     @id @default(uuid())
  email     String
  codeHash  String     @map("code_hash")
  purpose   OtpPurpose
  expiresAt DateTime   @map("expires_at")
  usedAt    DateTime?  @map("used_at")
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([email])
  @@index([codeHash])
  @@index([purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

// ===========================================
// CONFIGURATION ENTITIES
// ===========================================

/// ISO 3166-1 alpha-2 country reference data.
/// Seeded from prisma/data/countries-iso3166.json (250 rows). Treated as
/// reference / lookup table — admin UI is read-only with the optional
/// ability to override flagEmoji/region. All FKs from applications,
/// bindings, fees, and nationality references point here.
model Country {
  id            String    @id @default(uuid())
  isoCode       String    @unique @map("iso_code")
  name          String
  flagEmoji     String    @map("flag_emoji")
  continentCode String    @map("continent_code")
  region        String
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  page                        CountryPage?
  templateBindingsDestination TemplateBinding[]       @relation("DestinationCountry")
  bindingNationalityFees      BindingNationalityFee[] @relation("NationalityCountry")
  applicationsNationality     Application[]           @relation("NationalityCountry")
  applicationsDestination     Application[]           @relation("DestinationCountry")
  // M11.1 — homepage slides may link to a country (auto-derives slug + name).
  homepageSlides              HomepageSlide[]

  @@index([isoCode])
  @@index([continentCode])
  @@index([isActive])
  @@index([deletedAt])
  @@map("countries")
}

/// Publishable marketing page for a Country. Optional: a country can be
/// referenced as destination/nationality without having a page (the smart
/// dropdown in Sprint 4 / UX-001 derives offerable destinations from
/// active TemplateBindings, not from page presence). When a page exists,
/// it owns slug, SEO meta, and a list of CountrySection content blocks.
model CountryPage {
  id             String    @id @default(uuid())
  countryId      String    @unique @map("country_id")
  slug           String    @unique
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  isPublished    Boolean   @default(false) @map("is_published")
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  country  Country            @relation(fields: [countryId], references: [id])
  sections CountrySection[]
  // M11.1 — hero slider images managed per page.
  images   CountryPageImage[]

  @@index([countryId])
  @@index([slug])
  @@index([isPublished])
  @@index([isActive])
  @@index([deletedAt])
  @@map("country_pages")
}

/// `slot` decides which structured card SKIN the section renders with
/// on the public country page; `sortOrder` decides position. Two
/// sections may share a slot — public renderer just renders both in
/// their sortOrder positions. Default EXTRA = plain prose skin.
enum CountrySectionSlot {
  REQUIREMENTS
  PROCESSING_TIME
  ELIGIBILITY
  HOW_TO_APPLY
  EXTRA

  @@map("country_section_slot")
}

model CountrySection {
  id            String             @id @default(uuid())
  countryPageId String             @map("country_page_id")
  title         String
  content       String
  slot          CountrySectionSlot @default(EXTRA)
  sortOrder     Int                @default(0) @map("sort_order")
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")

  countryPage CountryPage @relation(fields: [countryPageId], references: [id], onDelete: Cascade)

  @@index([countryPageId])
  @@index([sortOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("country_sections")
}

model VisaType {
  id          String    @id @default(uuid())
  purpose     String
  label       String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Entries feature — validity / max stay / entry label moved to
  // per-entry rows. Each visa type seeds 3 defaults on create
  // (Single / Double / Multiple) which the admin can edit, reorder,
  // delete, or extend with custom entries.
  entries          VisaTypeEntry[]
  templateBindings TemplateBinding[]
  applications     Application[]

  @@index([purpose])
  @@index([isActive])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("visa_types")
}

/// Entries feature — one selectable entry option on a visa type
/// (e.g. Single / Double / Multiple, or an admin-created custom one).
/// `entryLabel` is free text so admins aren't bound to a fixed enum.
/// Pricing is per-entry: BindingNationalityFee carries an `entryId`.
model VisaTypeEntry {
  id           String    @id @default(uuid())
  visaTypeId   String    @map("visa_type_id")
  entryLabel   String    @map("entry_label")
  /// Optional stable machine key (e.g. 'single'); label can be renamed
  /// without breaking references that key off this.
  entryKey     String?   @map("entry_key")
  validityDays Int       @map("validity_days")
  maxStayDays  Int       @map("max_stay_days")
  sortOrder    Int       @default(0) @map("sort_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  visaType        VisaType                @relation(fields: [visaTypeId], references: [id], onDelete: Cascade)
  nationalityFees BindingNationalityFee[]

  @@index([visaTypeId])
  @@index([sortOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("visa_type_entries")
}

model Template {
  id            String    @id @default(uuid())
  name          String
  key           String    @unique
  description   String?
  version       Int       @default(1)
  isActive      Boolean   @default(true) @map("is_active")
  // M11.2 — boilerplates can be cloned but not bound to live
  // (nationality, destination, visaType) combos. Admin clones from a
  // boilerplate via POST /admin/templates/clone to start a real form.
  isBoilerplate Boolean   @default(false) @map("is_boilerplate")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  sections         TemplateSection[]
  templateBindings TemplateBinding[]
  applications     Application[]

  @@index([key])
  @@index([isActive])
  @@index([deletedAt])
  @@map("templates")
}

model TemplateSection {
  id          String    @id @default(uuid())
  templateId  String    @map("template_id")
  title       String
  key         String
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  template Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields   TemplateField[]

  @@unique([templateId, key])
  @@index([templateId])
  @@index([sortOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@map("template_sections")
}

model TemplateField {
  id                  String    @id @default(uuid())
  templateSectionId   String    @map("template_section_id")
  fieldKey            String    @map("field_key")
  fieldType           String    @map("field_type")
  label               String
  placeholder         String?
  helpText            String?   @map("help_text")
  defaultValue        String?   @map("default_value")
  isRequired          Boolean   @default(false) @map("is_required")
  sortOrder           Int       @default(0) @map("sort_order")
  isActive            Boolean   @default(true) @map("is_active")
  optionsJson         Json?     @map("options_json")
  validationRulesJson Json?     @map("validation_rules_json")
  visibilityRulesJson Json?     @map("visibility_rules_json")
  // M11.3 — locked system fields. `isSystem=true` means the field was
  // auto-provisioned (not authored by an admin); it is editable in the
  // limited ways the brief specifies (label/placeholder/helpText/sort/
  // visibility) but the admin cannot delete it, change its type, or
  // modify its validation. `systemKey` is the stable token used by
  // cross-field validators (e.g. "$passportExpiryDate") so admins can
  // safely rename labels without breaking date-keyword references.
  isSystem            Boolean   @default(false) @map("is_system")
  systemKey           String?   @map("system_key")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  templateSection TemplateSection @relation(fields: [templateSectionId], references: [id], onDelete: Cascade)

  // M11.13 (BUG Z) — uniqueness on (templateSectionId, fieldKey) is
  // enforced by a PARTIAL UNIQUE INDEX scoped to `deleted_at IS NULL`
  // rows (see migration 19_m11_13_template_fields_partial_unique).
  // Soft-deleting a field frees its (section_id, field_key) slot so
  // admins can re-add a previously-deleted key. Prisma's schema
  // DSL can't express partial unique indexes, so we drop @@unique
  // here and rely on the migration; a non-unique compound index
  // keeps the lookup fast. Anything that needs guaranteed-unique
  // active rows pre-checks via the service layer
  // (TemplateFieldsService.create) before INSERT.
  @@index([templateSectionId, fieldKey])
  @@index([templateSectionId])
  @@index([fieldKey])
  @@index([sortOrder])
  @@index([isActive])
  @@index([deletedAt])
  @@index([isSystem])
  @@index([systemKey])
  @@map("template_fields")
}

model TemplateBinding {
  id                   String    @id @default(uuid())
  destinationCountryId String    @map("destination_country_id")
  visaTypeId           String    @map("visa_type_id")
  templateId           String    @map("template_id")
  isActive             Boolean   @default(true) @map("is_active")
  validFrom            DateTime? @map("valid_from")
  validTo              DateTime? @map("valid_to")
  // M11.2 — per-binding expedited config. Pre-M11.2 the expedited
  // fields lived on each BindingNationalityFee — they still do for
  // backwards compat — but the binding-level values are now the
  // canonical source the public preview reads from. Admin sets these
  // once per (template, destination, visaType) combo via the bulk
  // destination manager. Migration backfills these from any existing
  // BindingNationalityFee that had expeditedEnabled=true.
  expeditedEnabled     Boolean   @default(false) @map("expedited_enabled")
  expeditedFeeAmount   Decimal?  @map("expedited_fee_amount") @db.Decimal(10, 2)
  // Flip-binding-flow: the M11.3 `min_arrival_days_advance` and the
  // M11.14 `processing_time_min` / `_max` columns moved down to
  // BindingNationalityFee.processing_days — see the new model below.
  // The earliest-selectable-arrival-date date floor that used to read
  // from this binding now reads the per-nationality processing_days
  // (or expedited_processing_days when expedited is on), so a
  // destination with two passport markets can quote different
  // processing windows.
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  destinationCountry Country                 @relation("DestinationCountry", fields: [destinationCountryId], references: [id])
  visaType           VisaType                @relation(fields: [visaTypeId], references: [id])
  template           Template                @relation(fields: [templateId], references: [id])
  nationalityFees    BindingNationalityFee[]
  applications       Application[]

  @@unique([destinationCountryId, visaTypeId])
  @@index([destinationCountryId])
  @@index([visaTypeId])
  @@index([templateId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("template_bindings")
}

model BindingNationalityFee {
  id                      String    @id @default(uuid())
  templateBindingId       String    @map("template_binding_id")
  nationalityCountryId    String    @map("nationality_country_id")
  // Entries feature — pricing is per (binding, nationality, entry).
  // Each entry of the bound visa type carries its own full fee set.
  entryId                 String    @map("entry_id")
  governmentFeeAmount     Decimal   @map("government_fee_amount") @db.Decimal(10, 2)
  serviceFeeAmount        Decimal   @map("service_fee_amount") @db.Decimal(10, 2)
  expeditedFeeAmount      Decimal?  @map("expedited_fee_amount") @db.Decimal(10, 2)
  currencyCode            String    @map("currency_code")
  expeditedEnabled        Boolean   @default(false) @map("expedited_enabled")
  // Flip-binding-flow — per-nationality processing windows. The standard
  // window (`processing_days`) is always set; the express window
  // (`expedited_processing_days`) is only meaningful when
  // `expedited_enabled` is true. The DB CHECK enforces
  // `expedited_processing_days < processing_days` whenever expedited
  // is on, so the customer always sees a strictly faster express
  // option.
  processingDays          Int       @default(3) @map("processing_days")
  expeditedProcessingDays Int?      @map("expedited_processing_days")
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  templateBinding    TemplateBinding @relation(fields: [templateBindingId], references: [id], onDelete: Cascade)
  nationalityCountry Country         @relation("NationalityCountry", fields: [nationalityCountryId], references: [id])
  entry              VisaTypeEntry   @relation(fields: [entryId], references: [id], onDelete: Restrict)

  @@unique([templateBindingId, nationalityCountryId, entryId])
  @@index([templateBindingId])
  @@index([nationalityCountryId])
  @@index([entryId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("binding_nationality_fees")
}

/// Module 5 — PaymentPageConfig singleton.
///
/// One row per environment (auto-created on first read). Migration 5
/// added 8 admin-facing columns matching the 3 admin UI tabs:
///   • Content: title, description, supportText, footerNote
///   • Layout: showCardLogos, showSecurityBadges
///   • Behavior: primaryButtonText, timeoutWarningMinutes,
///     termsCheckboxRequired, termsCheckboxText
///
/// `sectionsJson` stays in the schema as a forward-compatible slot for
/// the advanced section builder UI (Sprint 4 ticket); the Module 5
/// admin UI does not surface it yet.
model PaymentPageConfig {
  id                    String   @id @default(uuid())
  // Content
  title                 String
  description           String?
  supportText           String?  @map("support_text")
  footerNote            String?  @map("footer_note")
  // Layout
  showCardLogos         Boolean  @default(true) @map("show_card_logos")
  showSecurityBadges    Boolean  @default(true) @map("show_security_badges")
  // Behavior
  primaryButtonText     String   @default("Pay Now") @map("primary_button_text")
  /// Minutes before the unpaid-session warning fires on the public
  /// payment page. DTO clamps to 1-30.
  timeoutWarningMinutes Int      @default(5) @map("timeout_warning_minutes")
  termsCheckboxRequired Boolean  @default(false) @map("terms_checkbox_required")
  termsCheckboxText     String?  @map("terms_checkbox_text")
  // Forward-compat slot (advanced section builder, Sprint 4)
  sectionsJson          Json     @map("sections_json")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("payment_page_configs")
}

model EmailTemplate {
  id          String    @id @default(uuid())
  templateKey String    @unique @map("template_key")
  subject     String
  bodyHtml    String    @map("body_html")
  bodyText    String?   @map("body_text")
  /// Module 3 — admin-facing annotation explaining when this template
  /// fires (e.g. "Sent when user requests OTP during portal login").
  /// Optional, free-form text, capped at 500 chars at the DTO layer.
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([templateKey])
  @@index([isActive])
  @@index([deletedAt])
  @@map("email_templates")
}

/// Module 4 — Settings singleton.
///
/// One row per environment (auto-created on first read). The 13 columns
/// added in migration 4 round out the admin-facing surface area
/// (general / payment / email / application / maintenance / branding /
/// legal). SMTP-from fields and applicationCodeFormat are admin-editable
/// today but the runtime still reads .env / hardcoded format until the
/// Sprint 5 cutover ticket wires them up.
model Setting {
  id                          String  @id @default(uuid())
  // General
  siteName                    String  @map("site_name")
  siteUrl                     String  @default("") @map("site_url")
  supportEmail                String  @map("support_email")
  // Payment
  defaultCurrency             String  @default("USD") @map("default_currency")
  paymentTimeoutHours         Int     @default(3) @map("payment_timeout_hours")
  // Email (informational until Sprint 5 cutover)
  smtpFromAddress             String  @default("") @map("smtp_from_address")
  smtpFromName                String  @default("") @map("smtp_from_name")
  notificationEmailEnabled    Boolean @default(true) @map("notification_email_enabled")
  // Application (informational until Sprint 5 cutover)
  applicationCodeFormat       String  @default("EV-{YYYY}-{NNNN}") @map("application_code_format")
  maxApplicantsPerApplication Int     @default(10) @map("max_applicants_per_application")
  allowMultipleVisaTypes      Boolean @default(false) @map("allow_multiple_visa_types")
  // Maintenance
  maintenanceMode             Boolean @default(false) @map("maintenance_mode")
  maintenanceMessage          String? @map("maintenance_message")
  // Branding (logoUrl is consumed by the Sprint 4 frontend header)
  logoUrl                     String? @map("logo_url")
  faviconUrl                  String? @map("favicon_url")
  googleAnalyticsId           String? @map("google_analytics_id")
  // Legal
  termsUrl                    String? @map("terms_url")
  privacyUrl                  String? @map("privacy_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ===========================================
// APPLICATION DOMAIN ENTITIES
// ===========================================

model Application {
  id                      String            @id @default(uuid())
  /// M11.10 (BUG 4) — Booking-level reference code (REF-YYYY-NNNNNN).
  /// One per booking, shared by every applicant in it. Customer
  /// /tracks by EITHER this code or any per-applicant
  /// `application_applicants.application_code` — the lookup endpoint
  /// matches both columns. Nullable because pre-M11.10 rows pre-date
  /// the column; the migration backfills them.
  referenceCode           String?           @unique @map("reference_code")
  portalIdentityId        String            @map("portal_identity_id")
  nationalityCountryId    String            @map("nationality_country_id")
  destinationCountryId    String            @map("destination_country_id")
  visaTypeId              String            @map("visa_type_id")
  templateId              String            @map("template_id")
  templateBindingId       String            @map("template_binding_id")
  totalFeeAmount          Decimal           @map("total_fee_amount") @db.Decimal(10, 2)
  currencyCode            String            @map("currency_code")
  expedited               Boolean           @default(false)
  paymentStatus           PaymentStatus     @default(PENDING) @map("payment_status")
  paymentDeadlineAt       DateTime?         @map("payment_deadline_at")
  resumeToken             String            @unique @map("resume_token")
  currentStatus           ApplicationStatus @default(DRAFT) @map("current_status")
  // Admin review fields
  reviewedAt              DateTime?         @map("reviewed_at")
  reviewedByUserId        String?           @map("reviewed_by_user_id")
  adminNote               String?           @map("admin_note") @db.Text
  rejectionReason         String?           @map("rejection_reason") @db.Text
  requestedDocumentTypes  String[]          @default([]) @map("requested_document_types")
  // Module 9 — admin-supplied SLA estimate. Lives on the application
  // (not per-applicant) because the customer cares about the whole-
  // case turnaround. Each change is also logged in
  // ApplicationEstimatedTimeChange so the admin can see the
  // adjustment trail with reasons.
  estimatedProcessingDays Int?              @map("estimated_processing_days")
  estimatedTimeUpdatedAt  DateTime?         @map("estimated_time_updated_at")
  // Payment-window timeout job markers.
  //   paymentWarningSentAt — stamped when the "1h remaining" warning
  //     email fires, so the 10-min sweep never re-sends it.
  //   expiredReason — set to 'PAYMENT_WINDOW_EXPIRED' when the sweep
  //     soft-deletes an UNPAID app past its paymentDeadlineAt. Lets the
  //     resume endpoint distinguish a timeout cancellation from a
  //     never-existed token and surface the specific message.
  paymentWarningSentAt    DateTime?         @map("payment_warning_sent_at")
  expiredReason           String?           @map("expired_reason")
  // Timestamps
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  deletedAt               DateTime?         @map("deleted_at")

  portalIdentity     PortalIdentity  @relation(fields: [portalIdentityId], references: [id])
  nationalityCountry Country         @relation("NationalityCountry", fields: [nationalityCountryId], references: [id])
  destinationCountry Country         @relation("DestinationCountry", fields: [destinationCountryId], references: [id])
  visaType           VisaType        @relation(fields: [visaTypeId], references: [id])
  template           Template        @relation(fields: [templateId], references: [id])
  templateBinding    TemplateBinding @relation(fields: [templateBindingId], references: [id])
  reviewedByUser     User?           @relation("ApplicationReviewedByUser", fields: [reviewedByUserId], references: [id])
  // M-Assign — operator assignment columns. All nullable so
  // existing rows stay valid; assignment is opt-in by an
  // admin/super-admin.
  assignedToUserId   String?         @map("assigned_to")
  assignedAt         DateTime?       @map("assigned_at")
  assignedByUserId   String?         @map("assigned_by")

  applicants           ApplicationApplicant[]
  statusHistory        ApplicationStatusHistory[]
  estimatedTimeChanges ApplicationEstimatedTimeChange[]
  payments             Payment[]
  documentRequests     DocumentRequest[]
  // M-Assign relations
  assignedToUser       User?                            @relation("ApplicationAssignedTo", fields: [assignedToUserId], references: [id])
  assignedByUser       User?                            @relation("ApplicationAssignedBy", fields: [assignedByUserId], references: [id])
  internalNotes        ApplicationInternalNote[]
  assignmentHistory    ApplicationAssignmentHistory[]
  // M11.14 (BUG FF — PART 2) — issued-visa + supporting-files
  resultFiles          ApplicationResultFile[]

  @@index([portalIdentityId])
  @@index([nationalityCountryId])
  @@index([destinationCountryId])
  @@index([visaTypeId])
  @@index([templateId])
  @@index([templateBindingId])
  @@index([resumeToken])
  @@index([currentStatus])
  @@index([paymentStatus])
  @@index([reviewedByUserId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("applications")
}

model ApplicationApplicant {
  id                          String          @id @default(uuid())
  applicationId               String          @map("application_id")
  isMainApplicant             Boolean         @default(false) @map("is_main_applicant")
  email                       String
  phone                       String?
  formDataJson                Json            @map("form_data_json")
  status                      ApplicantStatus @default(DRAFT)
  // Module 9 — denormalized "last status touch" metadata so list
  // queries can render "READY (admin@x.com, 5m ago)" without a
  // join into ApplicantStatusHistory. The history table remains the
  // source of truth for the full timeline.
  statusUpdatedAt             DateTime?       @map("status_updated_at")
  statusUpdatedByUserId       String?         @map("status_updated_by_user_id")
  applicationCode             String?         @unique @map("application_code")
  resultFileName              String?         @map("result_file_name")
  resultStorageKey            String?         @map("result_storage_key")
  requiredDocumentsJson       Json?           @map("required_documents_json")
  additionalDocsRequestedJson Json?           @map("additional_docs_requested_json")
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")
  deletedAt                   DateTime?       @map("deleted_at")

  application   Application              @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  statusHistory ApplicantStatusHistory[]
  documents     Document[]
  // M11.14 (BUG FF) — result files scoped to this applicant
  resultFiles   ApplicationResultFile[]

  @@index([applicationId])
  @@index([applicationCode])
  @@index([email])
  @@index([status])
  @@index([isMainApplicant])
  @@index([deletedAt])
  @@map("application_applicants")
}

model ApplicationStatusHistory {
  id              String            @id @default(uuid())
  applicationId   String            @map("application_id")
  oldStatus       ApplicationStatus @map("old_status")
  newStatus       ApplicationStatus @map("new_status")
  note            String?
  changedByUserId String?           @map("changed_by_user_id")
  changedBySystem Boolean           @default(false) @map("changed_by_system")
  createdAt       DateTime          @default(now()) @map("created_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedByUser User?       @relation("ChangedByUser", fields: [changedByUserId], references: [id])

  @@index([applicationId])
  @@index([changedByUserId])
  @@index([createdAt])
  @@map("application_status_history")
}

model ApplicantStatusHistory {
  id                     String          @id @default(uuid())
  applicationApplicantId String          @map("application_applicant_id")
  oldStatus              ApplicantStatus @map("old_status")
  newStatus              ApplicantStatus @map("new_status")
  note                   String?
  changedByUserId        String?         @map("changed_by_user_id")
  changedBySystem        Boolean         @default(false) @map("changed_by_system")
  createdAt              DateTime        @default(now()) @map("created_at")

  applicationApplicant ApplicationApplicant @relation(fields: [applicationApplicantId], references: [id], onDelete: Cascade)
  changedByUser        User?                @relation("ChangedByUser", fields: [changedByUserId], references: [id])

  @@index([applicationApplicantId])
  @@index([changedByUserId])
  @@index([createdAt])
  @@map("applicant_status_history")
}

/// Module 9 — change-log for the application's SLA estimate.
/// Every adjustment requires a `reason` (admin can't silently move
/// goalposts on the customer). Read order: createdAt DESC for the
/// "last 5 changes" widget on the admin Operations Center.
model ApplicationEstimatedTimeChange {
  id              String   @id @default(uuid())
  applicationId   String   @map("application_id")
  /// Estimate before the change — null on the first time the admin
  /// sets an estimate (the application had no prior value).
  oldDays         Int?     @map("old_days")
  newDays         Int      @map("new_days")
  /// Required by the service layer, not nullable at DB level so old
  /// rows can never be retroactively reason-stripped. Empty string
  /// not allowed; min length enforced in DTO.
  reason          String   @db.Text
  changedByUserId String?  @map("changed_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedByUser User?       @relation("EstTimeChangedBy", fields: [changedByUserId], references: [id])

  @@index([applicationId])
  @@index([changedByUserId])
  @@index([createdAt])
  @@map("application_estimated_time_changes")
}

model Document {
  id                     String               @id @default(uuid())
  applicationApplicantId String               @map("application_applicant_id")
  documentTypeKey        String               @map("document_type_key")
  originalFileName       String               @map("original_file_name")
  storageFileName        String               @map("storage_file_name")
  storagePath            String               @map("storage_path")
  storageKey             String?              @map("storage_key")
  storageProvider        String               @default("local") @map("storage_provider")
  mimeType               String               @map("mime_type")
  fileSize               Int                  @map("file_size")
  checksum               String?              @map("checksum")
  reviewStatus           DocumentReviewStatus @default(PENDING) @map("review_status")
  reviewNote             String?              @map("review_note")
  uploadedAt             DateTime             @default(now()) @map("uploaded_at")
  reviewedAt             DateTime?            @map("reviewed_at")
  reviewedByUserId       String?              @map("reviewed_by_user_id")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  deletedAt              DateTime?            @map("deleted_at")

  applicationApplicant ApplicationApplicant  @relation(fields: [applicationApplicantId], references: [id], onDelete: Cascade)
  reviewedByUser       User?                 @relation("ReviewedByUser", fields: [reviewedByUserId], references: [id])
  documentRequestItems DocumentRequestItem[]

  @@index([applicationApplicantId])
  @@index([documentTypeKey])
  @@index([reviewStatus])
  @@index([reviewedByUserId])
  @@index([storageKey])
  @@index([deletedAt])
  @@map("documents")
}

/// M11.12 (BUG P) — Operator-issued additional-document request.
/// One row per "Need Documents" status change; the items table
/// captures the per-item asks (name + accepted formats + max size).
/// The legacy `applications.requested_document_types` array still
/// drives the existing customer /me upload UI for the launch
/// (lite-shipping path); this richer model exists for audit + the
/// post-launch upload page that reads accepted_formats / max_size_mb
/// per item and auto-flips status when every item is fulfilled.
model DocumentRequest {
  id            String    @id @default(uuid())
  applicationId String    @map("application_id")
  requestedBy   String    @map("requested_by")
  status        String    @default("pending") @db.VarChar(20)
  customMessage String?   @map("custom_message") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  fulfilledAt   DateTime? @map("fulfilled_at")

  application     Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  requestedByUser User                  @relation("DocumentRequestRequestedByUser", fields: [requestedBy], references: [id])
  items           DocumentRequestItem[]

  @@index([applicationId])
  @@index([status])
  @@index([createdAt])
  @@map("document_requests")
}

/// M-Assign — Internal operator-only note attached to an application.
/// Visible only to admin / operator roles; never sent to the customer.
/// Author can edit; super admin can delete. Soft-deletable.
model ApplicationInternalNote {
  id            String    @id @default(uuid())
  applicationId String    @map("application_id")
  userId        String    @map("user_id")
  note          String    @db.Text
  visibility    String    @default("internal") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([applicationId])
  @@index([userId])
  @@index([createdAt])
  @@map("application_internal_notes")
}

/// M-Assign — Append-only assignment audit. Lets the admin UI show
/// "X reassigned from Y to Z, reason: …" trails.
model ApplicationAssignmentHistory {
  id                 String   @id @default(uuid())
  applicationId      String   @map("application_id")
  previousAssigneeId String?  @map("previous_assignee_id")
  newAssigneeId      String?  @map("new_assignee_id")
  changedBy          String   @map("changed_by")
  reason             String?
  createdAt          DateTime @default(now()) @map("created_at")

  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  previousAssignee User?       @relation("AssignmentHistoryPreviousAssignee", fields: [previousAssigneeId], references: [id])
  newAssignee      User?       @relation("AssignmentHistoryNewAssignee", fields: [newAssigneeId], references: [id])
  changedByUser    User        @relation("AssignmentHistoryChangedBy", fields: [changedBy], references: [id])

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_assignment_history")
}

/// M11.14 (BUG FF) — operator-uploaded issued visa + supporting
/// files at the application (or applicant) level. One row per file.
/// `is_primary` marks the canonical visa PDF; partial unique index
/// in the migration enforces at most one primary per application.
model ApplicationResultFile {
  id              String    @id @default(uuid())
  applicationId   String    @map("application_id")
  applicantId     String?   @map("applicant_id")
  fileName        String    @map("file_name") @db.VarChar(255)
  storageKey      String    @map("storage_key")
  storagePath     String    @map("storage_path")
  storageProvider String    @default("local") @map("storage_provider")
  fileSize        Int?      @map("file_size")
  mimeType        String?   @map("mime_type") @db.VarChar(100)
  description     String?   @db.Text
  isPrimary       Boolean   @default(false) @map("is_primary")
  uploadedBy      String    @map("uploaded_by")
  uploadedAt      DateTime  @default(now()) @map("uploaded_at")
  deletedAt       DateTime? @map("deleted_at")

  application Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicant   ApplicationApplicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  uploader    User                  @relation(fields: [uploadedBy], references: [id])

  @@index([applicationId])
  @@index([applicantId])
  @@index([uploadedAt])
  @@map("application_result_files")
}

model DocumentRequestItem {
  id                 String    @id @default(uuid())
  requestId          String    @map("request_id")
  documentName       String    @map("document_name") @db.VarChar(200)
  acceptedFormats    String?   @map("accepted_formats") @db.Text
  maxSizeMb          Int       @default(10) @map("max_size_mb")
  uploadedDocumentId String?   @map("uploaded_document_id")
  uploadedAt         DateTime? @map("uploaded_at")

  request          DocumentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedDocument Document?       @relation(fields: [uploadedDocumentId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([uploadedDocumentId])
  @@map("document_request_items")
}

// ===========================================
// PAYMENT ENTITIES
// ===========================================

model Payment {
  id                  String        @id @default(uuid())
  applicationId       String        @map("application_id")
  paymentReference    String        @unique @map("payment_reference")
  paymentProviderKey  String        @map("payment_provider_key")
  paymentMethodKey    String?       @map("payment_method_key")
  currencyCode        String        @map("currency_code")
  governmentFeeAmount Decimal       @map("government_fee_amount") @db.Decimal(10, 2)
  serviceFeeAmount    Decimal       @map("service_fee_amount") @db.Decimal(10, 2)
  expeditedFeeAmount  Decimal?      @map("expedited_fee_amount") @db.Decimal(10, 2)
  totalAmount         Decimal       @map("total_amount") @db.Decimal(10, 2)
  payableAmount       Decimal       @map("payable_amount") @db.Decimal(10, 2)
  paymentStatus       PaymentStatus @default(PENDING) @map("payment_status")
  providerPaymentId   String?       @map("provider_payment_id")
  providerSessionId   String?       @map("provider_session_id")
  providerOrderId     String?       @map("provider_order_id")
  idempotencyKey      String?       @unique @map("idempotency_key")
  expiresAt           DateTime?     @map("expires_at")
  paidAt              DateTime?     @map("paid_at")
  failedAt            DateTime?     @map("failed_at")
  cancelledAt         DateTime?     @map("cancelled_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")

  application    Application             @relation(fields: [applicationId], references: [id])
  transactions   PaymentTransaction[]
  statusHistory  PaymentStatusHistory[]
  callbacks      PaymentCallback[]
  reconciliation PaymentReconciliation[]

  @@index([applicationId])
  @@index([paymentReference])
  @@index([paymentProviderKey])
  @@index([paymentStatus])
  @@index([idempotencyKey])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("payments")
}

model PaymentTransaction {
  id                           String            @id @default(uuid())
  paymentId                    String            @map("payment_id")
  transactionType              TransactionType   @map("transaction_type")
  transactionStatus            TransactionStatus @map("transaction_status")
  internalTransactionReference String            @unique @map("internal_transaction_reference")
  providerTransactionReference String?           @map("provider_transaction_reference")
  providerEventKey             String?           @map("provider_event_key")
  requestPayloadJson           Json?             @map("request_payload_json")
  responsePayloadJson          Json?             @map("response_payload_json")
  errorCode                    String?           @map("error_code")
  errorMessage                 String?           @map("error_message")
  processedAt                  DateTime?         @map("processed_at")
  createdAt                    DateTime          @default(now()) @map("created_at")

  payment   Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  callbacks PaymentCallback[]

  @@index([paymentId])
  @@index([internalTransactionReference])
  @@index([transactionType])
  @@index([transactionStatus])
  @@index([createdAt])
  @@map("payment_transactions")
}

model PaymentStatusHistory {
  id              String        @id @default(uuid())
  paymentId       String        @map("payment_id")
  oldStatus       PaymentStatus @map("old_status")
  newStatus       PaymentStatus @map("new_status")
  changeReason    String?       @map("change_reason")
  changedByUserId String?       @map("changed_by_user_id")
  changedBySystem Boolean       @default(false) @map("changed_by_system")
  createdAt       DateTime      @default(now()) @map("created_at")

  payment       Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  changedByUser User?   @relation("ChangedByUser", fields: [changedByUserId], references: [id])

  @@index([paymentId])
  @@index([changedByUserId])
  @@index([createdAt])
  @@map("payment_status_history")
}

model PaymentCallback {
  id                        String                    @id @default(uuid())
  paymentId                 String                    @map("payment_id")
  paymentTransactionId      String?                   @map("payment_transaction_id")
  providerKey               String                    @map("provider_key")
  callbackType              String                    @map("callback_type")
  providerEventId           String?                   @map("provider_event_id")
  headersJson               Json?                     @map("headers_json")
  payloadJson               Json                      @map("payload_json")
  signatureValidationStatus SignatureValidationStatus @default(NOT_CHECKED) @map("signature_validation_status")
  processingStatus          CallbackProcessingStatus  @default(PENDING) @map("processing_status")
  errorMessage              String?                   @map("error_message")
  receivedAt                DateTime                  @default(now()) @map("received_at")
  processedAt               DateTime?                 @map("processed_at")

  payment            Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])

  @@index([paymentId])
  @@index([paymentTransactionId])
  @@index([providerKey])
  @@index([processingStatus])
  @@index([receivedAt])
  @@map("payment_callbacks")
}

model PaymentReconciliation {
  id                           String               @id @default(uuid())
  paymentId                    String               @map("payment_id")
  reconciliationStatus         ReconciliationStatus @default(PENDING) @map("reconciliation_status")
  providerReportedAmount       Decimal?             @map("provider_reported_amount") @db.Decimal(10, 2)
  providerReportedCurrencyCode String?              @map("provider_reported_currency_code")
  providerReportedStatus       String?              @map("provider_reported_status")
  checkedAt                    DateTime?            @map("checked_at")
  note                         String?
  createdAt                    DateTime             @default(now()) @map("created_at")
  updatedAt                    DateTime             @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([reconciliationStatus])
  @@index([checkedAt])
  @@map("payment_reconciliations")
}

// ===========================================
// SUPPORT ENTITIES
// ===========================================

model Notification {
  id            String              @id @default(uuid())
  channel       NotificationChannel
  templateKey   String              @map("template_key")
  recipient     String
  subject       String?
  payloadJson   Json                @map("payload_json")
  status        NotificationStatus  @default(PENDING)
  retryCount    Int                 @default(0) @map("retry_count")
  maxRetryCount Int                 @default(3) @map("max_retry_count")
  provider      String? // Provider used for sending (smtp, console, etc.)
  messageId     String?             @map("message_id") // External message ID from provider
  sentAt        DateTime?           @map("sent_at")
  failedAt      DateTime?           @map("failed_at")
  errorMessage  String?             @map("error_message")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([channel])
  @@index([templateKey])
  @@index([recipient])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model Job {
  id            String    @id @default(uuid())
  jobType       String    @map("job_type")
  payloadJson   Json      @map("payload_json")
  status        JobStatus @default(PENDING)
  scheduledAt   DateTime? @map("scheduled_at")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  retryCount    Int       @default(0) @map("retry_count")
  maxRetryCount Int       @default(3) @map("max_retry_count")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  executions JobExecution[]

  @@index([jobType])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("jobs")
}

model JobExecution {
  id              String             @id @default(uuid())
  jobId           String             @map("job_id")
  executionStatus JobExecutionStatus @map("execution_status")
  startedAt       DateTime           @default(now()) @map("started_at")
  finishedAt      DateTime?          @map("finished_at")
  errorMessage    String?            @map("error_message")
  createdAt       DateTime           @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([executionStatus])
  @@index([startedAt])
  @@map("job_executions")
}

/// M11.5 — Twin-channel Telegram notifications.
/// Append-only log of every event the platform fires; the admin
/// /notifications page renders this directly. The `status` column
/// drives the retry processor (`pending` → `sent` | `failed`) and
/// the `skipped` state when TELEGRAM_ENABLED=false (so the UI feed
/// keeps working when Telegram is muted).
model NotificationEvent {
  id           String    @id @default(uuid())
  /// e.g. `app.submitted`, `payment.failed`. Stable string key from
  /// EVENT_REGISTRY in src/modules/notifications/event-registry.ts.
  eventType    String    @map("event_type")
  /// `alert` | `activity` — drives sidebar grouping in the UI feed.
  severity     String
  /// `alerts` | `activity` — which Telegram channel this targets.
  channel      String
  title        String
  body         String
  contextJson  Json?     @map("context_json")
  status       String    @default("pending")
  attemptCount Int       @default(0) @map("attempt_count")
  lastError    String?   @map("last_error")
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([channel, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("notification_events")
}

/// M11.5 — admin per-event-type toggle. Seeded from EVENT_REGISTRY;
/// admin can flip any row off via /admin/settings → Notifications.
/// Soft-disable (the row stays, `enabled=false`) so the UI feed's
/// list of "what events exist" survives toggling.
model NotificationSetting {
  eventType   String   @id @map("event_type")
  enabled     Boolean  @default(true)
  channel     String
  description String?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model AuditLog {
  id           String    @id @default(uuid())
  actorUserId  String?   @map("actor_user_id")
  actorType    ActorType @map("actor_type")
  actionKey    String    @map("action_key")
  entityType   String    @map("entity_type")
  entityId     String    @map("entity_id")
  oldValueJson Json?     @map("old_value_json")
  newValueJson Json?     @map("new_value_json")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  actorUser User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([actorType])
  @@index([actionKey])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===========================================
// EMAIL LOGGING
// ===========================================

enum EmailLogStatus {
  PENDING
  SENT
  FAILED
}

model EmailLog {
  id              String         @id @default(uuid())
  templateKey     String         @map("template_key")
  recipient       String
  subject         String?
  provider        String
  status          EmailLogStatus @default(PENDING)
  messageId       String?        @map("message_id")
  errorMessage    String?        @map("error_message")
  errorCode       String?        @map("error_code")
  retryCount      Int            @default(0) @map("retry_count")
  // Reference to related entity (notification, otp, etc.)
  relatedEntity   String?        @map("related_entity")
  relatedEntityId String?        @map("related_entity_id")
  // Metadata
  metadataJson    Json?          @map("metadata_json")
  sentAt          DateTime?      @map("sent_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([templateKey])
  @@index([recipient])
  @@index([provider])
  @@index([status])
  @@index([relatedEntity, relatedEntityId])
  @@index([createdAt])
  @@map("email_logs")
}

// ===========================================
// MODULE 11.B — CONTENT MANAGEMENT (CMS)
// ===========================================
// Admin-managed copy for the public marketing pages (about / privacy /
// terms / contact / faq) plus a contact-info singleton that drives the
// site footer. All three tables are designed to be edited live without
// a redeploy. Public reads are unauthenticated; writes require the
// `content.update` permission.

/// Markdown/HTML body for one public marketing page, addressed by slug
/// from the public router (e.g. `/about` → slug='about'). One row per
/// page; slug is the natural unique key.
model ContentPage {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  contentHtml     String    @map("content_html")
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  isPublished     Boolean   @default(true) @map("is_published")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  deletedAt       DateTime? @map("deleted_at")

  @@index([slug])
  @@index([isPublished, deletedAt])
  @@map("content_pages")
}

/// Singleton — one row per environment, holds the contact / hours /
/// social-link info shown in the footer + on /contact. Service layer
/// auto-creates on first read so no NPE if the seed hasn't run yet.
model ContactInfo {
  id              String   @id @default(uuid())
  email           String
  phone           String?
  whatsapp        String?
  address         String?
  city            String?
  country         String?
  businessHours   String?  @map("business_hours")
  supportHours    String?  @map("support_hours")
  // socialLinks shape: { facebook?, twitter?, instagram?, linkedin?, ... }
  socialLinksJson Json?    @map("social_links_json")
  // M11.10 (BUG 7) — Secondary contact channels. Pragmatic scope cut
  // vs the full dynamic-channels feature in the brief: covers the
  // actual reported pain ("I want a Phone 2 / Email 2 / Telegram /
  // sales address"). Each is independently nullable so admins keep
  // the M11.7 hide-when-blank behavior on the public /contact page.
  // Full dynamic channel-types (CRUD-able list per type) is queued
  // for post-launch.
  email2          String?  @map("email_2")
  phone2          String?  @map("phone_2")
  whatsapp2       String?  @map("whatsapp_2")
  telegram        String?
  /// Free-form copy block surfaced under contact entries on /contact —
  /// e.g. "Sales: anar@... · Emergency: +994 XX XXX..."
  customNote      String?  @map("custom_note") @db.Text
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedByUserId String?  @map("updated_by_user_id")

  @@map("contact_info")
}

/// M11.7 (C1) — FAQ category lookup. `key` is the slug stored on
/// `FaqItem.category` (soft FK by string — no UUID join needed, and
/// existing rows keep working). Admin can rename `displayName` and
/// reorder via `displayOrder` without touching items. Categories not
/// referenced by any item still appear in the admin Categories tab,
/// but the public endpoint only emits groups that have at least one
/// published item.
model FaqCategory {
  id           String    @id @default(uuid())
  key          String    @unique
  displayName  String    @map("display_name")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([displayOrder])
  @@index([isActive, deletedAt])
  @@map("faq_categories")
}

/// One Q+A on the public /faq page. `category` is a soft FK to
/// `FaqCategory.key` (kept as a string so legacy items survive any
/// future rename/migrate without data loss). `displayOrder` is the
/// per-category sort key used by the admin drag-drop reorder
/// endpoint.
model FaqItem {
  id              String    @id @default(uuid())
  question        String
  answer          String
  category        String?
  displayOrder    Int       @default(0) @map("display_order")
  isPublished     Boolean   @default(true) @map("is_published")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  deletedAt       DateTime? @map("deleted_at")

  @@index([category, displayOrder])
  @@index([isPublished, deletedAt])
  @@map("faq_items")
}

// ===========================================
// MODULE 11.1 — CAROUSEL & COUNTRY-PAGE IMAGES
// ===========================================
// Two additive tables for the public marketing surface:
//   • CountryPageImage — hero-slider images per country page
//   • HomepageSlide    — promotional carousel cards on the homepage
// Both are admin-managed (countryPages.update + homepageSlides.update),
// store the file via the existing StorageService abstraction, and
// expose published-only public read endpoints.

/// Hero-slider images for a public country page (one CountryPage → many).
/// `imageUrl` holds the storage key (relative path inside the storage
/// provider) — frontend resolves it through the existing signed-URL
/// flow if needed, or treats it as a relative path under the storage
/// CDN base URL.
model CountryPageImage {
  id              String    @id @default(uuid())
  countryPageId   String    @map("country_page_id")
  imageUrl        String    @map("image_url")
  altText         String?   @map("alt_text")
  displayOrder    Int       @default(0) @map("display_order")
  isPublished     Boolean   @default(true) @map("is_published")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  deletedAt       DateTime? @map("deleted_at")

  countryPage CountryPage @relation(fields: [countryPageId], references: [id], onDelete: Cascade)

  @@index([countryPageId, displayOrder])
  @@index([isPublished, deletedAt])
  @@map("country_page_images")
}

/// One promotional card on the homepage carousel. `countryId` is
/// optional — when set, the frontend auto-derives the CTA URL to
/// `/country/{country.page.slug}` and falls back to the country flag
/// when no `imageUrl` is uploaded.
model HomepageSlide {
  id              String    @id @default(uuid())
  countryId       String?   @map("country_id")
  imageUrl        String?   @map("image_url")
  title           String
  subtitle        String?
  ctaText         String    @default("Apply Now") @map("cta_text")
  ctaUrl          String?   @map("cta_url")
  displayOrder    Int       @default(0) @map("display_order")
  isPublished     Boolean   @default(true) @map("is_published")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  deletedAt       DateTime? @map("deleted_at")

  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([displayOrder])
  @@index([isPublished, deletedAt])
  @@map("homepage_slides")
}

// =====================================================================
// M11.15 (HELP) — Operator help / training articles
// =====================================================================

/// A workflow-grouped bucket for help articles (e.g. "Applications",
/// "Users & Roles"). Mirrors the FAQ-categories pattern from BUG SS —
/// the canonical seeded set is system-protected and can't be deleted,
/// new ones can be added by an admin.
model HelpCategory {
  id          String    @id @default(uuid())
  key         String
  name        String    @db.VarChar(100)
  description String?
  iconName    String?   @map("icon_name") @db.VarChar(50)
  sortOrder   Int       @default(0) @map("sort_order")
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  articles HelpArticle[]

  @@map("help_categories")
}

/// One help article. The authoring editor sends Markdown which the
/// service renders to HTML server-side; both stay on the row so a
/// later edit round-trips without re-rendering and so the read view
/// ships static HTML directly.
model HelpArticle {
  id                   String    @id @default(uuid())
  slug                 String    @db.VarChar(150)
  title                String    @db.VarChar(200)
  categoryId           String?   @map("category_id")
  summary              String?
  contentHtml          String?   @map("content_html")
  contentMarkdown      String?   @map("content_markdown")
  videoUrl             String?   @map("video_url") @db.VarChar(500)
  videoProvider        String?   @map("video_provider") @db.VarChar(20)
  // M11.15-HELP-V2 — self-hosted video alternative (XOR with videoUrl,
  // enforced at the DB layer by the help_articles_video_xor check).
  videoFilePath        String?   @map("video_file_path")
  videoStorageType     String?   @map("video_storage_type") @db.VarChar(10)
  videoSizeBytes       BigInt?   @map("video_size_bytes")
  videoDurationSeconds Int?      @map("video_duration_seconds")
  videoMimeType        String?   @map("video_mime_type") @db.VarChar(60)
  sortOrder            Int       @default(0) @map("sort_order")
  isPublished          Boolean   @default(false) @map("is_published")
  tags                 String[]  @default([])
  viewCount            Int       @default(0) @map("view_count")
  visibleToRoles       String[]  @default(["operator", "admin", "superAdmin"]) @map("visible_to_roles")
  createdAt            DateTime  @default(now()) @map("created_at")
  createdBy            String?   @map("created_by")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  updatedBy            String?   @map("updated_by")
  deletedAt            DateTime? @map("deleted_at")

  category HelpCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creator  User?              @relation("HelpArticleCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater  User?              @relation("HelpArticleUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  images   HelpArticleImage[]

  @@map("help_articles")
}

/// Per-article screenshot gallery. Files live under
/// uploads/help/{articleId}/ via the shared StorageService.
model HelpArticleImage {
  id         String    @id @default(uuid())
  articleId  String    @map("article_id")
  storageKey String    @map("storage_key")
  fileSize   Int?      @map("file_size")
  mimeType   String?   @map("mime_type") @db.VarChar(60)
  caption    String?
  altText    String?   @map("alt_text")
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  article HelpArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("help_article_images")
}
